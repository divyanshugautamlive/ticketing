# Authentication
JWT_SECRET=generate-a-secure-32-character-or-longer-string
JWT_REFRESH_SECRET=generate-another-secure-32-character-or-longer-string
BCRYPT_SALT_ROUNDS=12

# Cryptography (Used for sensitive traveler PII encryption)
# Key must be exactly 32 bytes (64 hex characters)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
HASH_SALT=another-random-salt-string-for-one-way-hashes

# Environment
NODE_ENV=development
